{
  "meta": {
    "name": "Minimalist Monochrome",
    "version": "1.0.0",
    "description": "An editorial, luxury-grade design system built on pure black and white with zero accent colors. Typography is the primary visual element — oversized serif headlines function as graphic elements. Depth is achieved through color inversion, border weight variation, and layered subtle textures rather than shadows or gradients. Every corner is sharp, every transition is instant, every decision is deliberate. Inspired by high-end fashion editorials, architectural monographs, and luxury brand identities.",
    "mood_keywords": [
      "austere",
      "authoritative",
      "timeless",
      "editorial",
      "intellectual",
      "dramatic",
      "refined",
      "stark",
      "confident",
      "uncompromising"
    ],
    "style_references": [
      "high-end fashion editorial (Vogue, Harper's Bazaar)",
      "architectural monographs and museum catalogs",
      "luxury brand identity (Chanel, Celine, Bottega Veneta)",
      "award-winning book design and fine typography",
      "gallery exhibition materials",
      "Bauhaus meets editorial print"
    ],
    "anti_patterns": [
      "colorful or playful",
      "soft, rounded, or friendly",
      "gradient-based or with accent colors",
      "shadow-heavy or elevated",
      "generic or template-like",
      "busy or cluttered",
      "Minimalist Modern with colors removed"
    ],
    "success_feels_like": [
      "opening a high-end fashion magazine",
      "walking through a modern art gallery",
      "reading an award-winning architectural monograph",
      "browsing a luxury brand's website"
    ],
    "companion_file": "minimalist_monochrome_design_system.md is the primary implementation guide with prose reasoning and dashboard-specific component mappings. This JSON is the structured token reference. If anything conflicts, follow the MD."
  },

  "colors": {
    "background": "#FFFFFF",
    "foreground": "#000000",
    "muted": "#F5F5F5",
    "muted_foreground": "#525252",
    "accent": "#000000",
    "accent_foreground": "#FFFFFF",
    "border": "#000000",
    "border_light": "#E5E5E5",
    "card": "#FFFFFF",
    "card_foreground": "#000000",
    "ring": "#000000",

    "rule": "No other colors. Ever. The palette is absolute. Black IS the accent.",

    "inverted": {
      "background": "#000000",
      "foreground": "#FFFFFF",
      "muted": "#1A1A1A",
      "muted_foreground": "#A3A3A3",
      "border": "#FFFFFF",
      "border_light": "rgba(255, 255, 255, 0.2)",
      "card": "#000000",
      "card_foreground": "#FFFFFF",
      "ring": "#FFFFFF",
      "usage": "Use sparingly for emphasis: stats sections, highlighted cards, CTAs, pull quotes"
    },

    "palette": [
      "#000000",
      "#FFFFFF",
      "#F5F5F5",
      "#E5E5E5",
      "#525252"
    ],

    "dark_mode": {
      "background": "#000000",
      "foreground": "#FFFFFF",
      "muted": "#1A1A1A",
      "muted_foreground": "#A3A3A3",
      "border": "#FFFFFF",
      "border_light": "#333333",
      "card": "#000000",
      "card_foreground": "#FFFFFF",
      "ring": "#FFFFFF",
      "note": "Full page inversion as dark mode. Maintains monochrome constraint. Applied via [data-theme='dark'] on html element."
    }
  },

  "typography": {
    "font_families": {
      "display": "'Playfair Display', Georgia, serif",
      "body": "'Source Serif 4', Georgia, serif",
      "mono": "'JetBrains Mono', monospace"
    },
    "font_family_usage": {
      "display": "Headlines, hero text, section titles, pull quotes, editorial emphasis — the primary visual element of the entire system",
      "body": "Body text, paragraphs, descriptions, long-form content — highly readable serif for sustained reading",
      "mono": "Dates, metadata, labels, technical details, small caps, navigation counters"
    },
    "google_fonts_import": "https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,500;1,600;1,700;1,800;1,900&family=Source+Serif+4:ital,opsz,wght@0,8..60,300;0,8..60,400;0,8..60,500;0,8..60,600;0,8..60,700;1,8..60,300;1,8..60,400;1,8..60,500&family=JetBrains+Mono:wght@300;400;500&display=swap",
    "scale": {
      "xs": { "size": "0.75rem", "px": "12px", "usage": "fine print, metadata" },
      "sm": { "size": "0.875rem", "px": "14px", "usage": "captions, labels" },
      "base": { "size": "1rem", "px": "16px", "usage": "body text minimum" },
      "lg": { "size": "1.125rem", "px": "18px", "usage": "body text preferred" },
      "xl": { "size": "1.25rem", "px": "20px", "usage": "lead paragraphs" },
      "2xl": { "size": "1.5rem", "px": "24px", "usage": "section intros" },
      "3xl": { "size": "2rem", "px": "32px", "usage": "subheadings" },
      "4xl": { "size": "2.5rem", "px": "40px", "usage": "section titles" },
      "5xl": { "size": "3.5rem", "px": "56px", "usage": "page titles" },
      "6xl": { "size": "4.5rem", "px": "72px", "usage": "hero subheadings" },
      "7xl": { "size": "6rem", "px": "96px", "usage": "hero headlines" },
      "8xl": { "size": "8rem", "px": "128px", "usage": "display headlines — words as graphic elements" },
      "9xl": { "size": "10rem", "px": "160px", "usage": "oversized statements — single words filling viewport width" }
    },
    "font_weights": {
      "light": 300,
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700,
      "extrabold": 800,
      "black": 900
    },
    "letter_spacing": {
      "tighter": "-0.05em",
      "tight": "-0.025em",
      "normal": "0em",
      "wide": "0.025em",
      "wider": "0.05em",
      "widest": "0.1em"
    },
    "letter_spacing_usage": {
      "tighter": "oversized display headlines (8xl, 9xl)",
      "tight": "standard headlines (5xl–7xl)",
      "normal": "body text",
      "widest": "small caps, labels, button text, metadata"
    },
    "line_heights": {
      "none": 1.0,
      "tight": 1.1,
      "snug": 1.2,
      "normal": 1.5,
      "relaxed": 1.625,
      "loose": 1.8
    },
    "line_height_usage": {
      "none": "display headlines (7xl+) — type as graphic, no leading",
      "tight": "headlines (4xl–6xl)",
      "snug": "subheadings (3xl)",
      "relaxed": "body text — comfortable reading rhythm"
    },
    "defaults": {
      "body": {
        "family": "body",
        "size": "lg",
        "weight": "regular",
        "line_height": "relaxed",
        "letter_spacing": "normal",
        "color": "#000000"
      },
      "heading_1": {
        "family": "display",
        "size": "7xl",
        "weight": "bold",
        "line_height": "none",
        "letter_spacing": "tight",
        "color": "#000000",
        "note": "Hero-level — words function as graphic elements"
      },
      "heading_2": {
        "family": "display",
        "size": "5xl",
        "weight": "bold",
        "line_height": "tight",
        "letter_spacing": "tight",
        "color": "#000000"
      },
      "heading_3": {
        "family": "display",
        "size": "3xl",
        "weight": "semibold",
        "line_height": "snug",
        "letter_spacing": "normal",
        "color": "#000000"
      },
      "heading_4": {
        "family": "display",
        "size": "2xl",
        "weight": "semibold",
        "line_height": "snug",
        "letter_spacing": "normal",
        "color": "#000000"
      },
      "display_oversized": {
        "family": "display",
        "size": "9xl",
        "weight": "black",
        "line_height": "none",
        "letter_spacing": "tighter",
        "color": "#000000",
        "note": "At least one word in 8xl+ is non-negotiable for hero sections"
      },
      "label": {
        "family": "mono",
        "size": "xs",
        "weight": "medium",
        "line_height": "none",
        "letter_spacing": "widest",
        "text_transform": "uppercase",
        "color": "#525252"
      },
      "caption": {
        "family": "mono",
        "size": "xs",
        "weight": "regular",
        "line_height": "normal",
        "letter_spacing": "wide",
        "color": "#525252"
      },
      "pull_quote": {
        "family": "display",
        "size": "4xl",
        "weight": "regular",
        "line_height": "snug",
        "letter_spacing": "tight",
        "font_style": "italic",
        "color": "#000000",
        "note": "Large italic serif with oversized quotation marks"
      },
      "nav_item": {
        "family": "mono",
        "size": "sm",
        "weight": "medium",
        "letter_spacing": "widest",
        "text_transform": "uppercase",
        "color": "#000000"
      }
    }
  },

  "spacing": {
    "base_unit": "4px",
    "scale": {
      "0": "0px",
      "1": "4px",
      "2": "8px",
      "3": "12px",
      "4": "16px",
      "5": "20px",
      "6": "24px",
      "7": "32px",
      "8": "40px",
      "9": "48px",
      "10": "64px",
      "11": "96px",
      "12": "128px",
      "13": "160px"
    },
    "section_padding": {
      "mobile": "96px 0",
      "tablet": "128px 0",
      "desktop": "160px 0",
      "note": "Dramatic negative space between sections — whitespace is active, not empty"
    }
  },

  "radius": {
    "ALL": "0px",
    "note": "Zero border radius everywhere. No exceptions. Every element has sharp 90-degree corners. This is non-negotiable and defines the style's architectural character."
  },

  "borders": {
    "hairline": { "width": "1px", "style": "solid", "color": "#E5E5E5", "usage": "subtle dividers, background structure" },
    "thin": { "width": "1px", "style": "solid", "color": "#000000", "usage": "standard borders, card outlines, vertical dividers" },
    "medium": { "width": "2px", "style": "solid", "color": "#000000", "usage": "emphasis borders, secondary section dividers" },
    "thick": { "width": "4px", "style": "solid", "color": "#000000", "usage": "heavy rules between ALL major sections — non-negotiable" },
    "ultra": { "width": "8px", "style": "solid", "color": "#000000", "usage": "maximum impact, hero decorative elements" },
    "inverted": {
      "thin": { "width": "1px", "style": "solid", "color": "#FFFFFF" },
      "medium": { "width": "2px", "style": "solid", "color": "#FFFFFF" },
      "thick": { "width": "4px", "style": "solid", "color": "#FFFFFF" }
    }
  },

  "shadows": {
    "ALL": "none",
    "note": "Zero drop shadows. Depth is created exclusively through: color inversion (black/white swap), border weight variation, scale contrast, and negative space."
  },

  "textures": {
    "note": "CRITICAL — these textures are REQUIRED to prevent flat design. Apply strategically across sections. They provide paper-like depth and editorial quality.",
    "horizontal_lines": {
      "css": "repeating-linear-gradient(0deg, transparent, transparent 1px, #000 1px, #000 2px)",
      "background_size": "100% 4px",
      "opacity": 0.015,
      "usage": "Global — primary pattern for light backgrounds"
    },
    "grid": {
      "css": "linear-gradient(#00000008 1px, transparent 1px), linear-gradient(90deg, #00000008 1px, transparent 1px)",
      "background_size": "40px 40px",
      "opacity": 0.015,
      "usage": "Editorial sections, product detail areas"
    },
    "diagonal_lines": {
      "css": "repeating-linear-gradient(45deg, transparent, transparent 40px, #00000008 40px, #00000008 42px)",
      "opacity": 0.01,
      "usage": "Process sections, timelines, steps"
    },
    "noise": {
      "css": "url(\"data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E\")",
      "opacity": 0.02,
      "usage": "Global overlay — gives paper-like quality to all surfaces"
    },
    "inverted_vertical_lines": {
      "css": "repeating-linear-gradient(90deg, transparent, transparent 1px, #fff 1px, #fff 2px)",
      "background_size": "4px 100%",
      "opacity": 0.03,
      "usage": "Dark/inverted sections like stats bars"
    },
    "inverted_radial": {
      "css": "radial-gradient(circle at top center, #ffffff, transparent 70%)",
      "opacity": 0.05,
      "usage": "Dark/inverted CTA sections — subtle light bloom at top"
    }
  },

  "motion": {
    "philosophy": "Minimal and Instant. Favor stillness and instant state changes. Animation is binary (sharp on/off), never gradual or bouncy.",
    "durations": {
      "instant": "0ms",
      "snap": "100ms",
      "note": "100ms is the absolute maximum. Most interactions should be 0ms (transition-none)."
    },
    "easing": {
      "default": "linear",
      "note": "No easing functions. Instant state flips. The only exception is blog image scale (300ms for grayscale removal)."
    },
    "forbidden": [
      "bouncy animations",
      "floating elements",
      "parallax scrolling",
      "slow easing functions (ease-in-out, cubic-bezier curves)",
      "gradient animations",
      "spring physics",
      "staggered reveals (unless page load)"
    ],
    "component_guidelines": {
      "card_hover": {
        "effect": "full color inversion (bg, text, borders)",
        "duration": "100ms",
        "css_class_hint": "group transition-colors duration-100 hover:bg-[var(--foreground)] hover:text-[var(--background)]"
      },
      "button_hover": {
        "effect": "color inversion",
        "duration": "0ms",
        "css_class_hint": "transition-none"
      },
      "image_hover": {
        "effect": "border thickens (2px → 4px), image scales 105%, grayscale removed",
        "duration": "300ms (exception for image filter)",
        "css_class_hint": "grayscale transition-all duration-300 group-hover:scale-105 group-hover:grayscale-0"
      },
      "link_hover": {
        "effect": "underline appears",
        "duration": "0ms"
      },
      "testimonial_hover": {
        "effect": "quote mark opacity increases, bottom border thickens",
        "duration": "100ms"
      }
    }
  },

  "components": {
    "button": {
      "primary": {
        "background": "#000000",
        "color": "#FFFFFF",
        "border": "2px solid #000000",
        "border_note": "Use 2px solid black (invisible against black bg) in default state to prevent layout shift on hover",
        "padding": "16px 32px",
        "font_family": "mono",
        "font_size": "0.875rem",
        "font_weight": 500,
        "text_transform": "uppercase",
        "letter_spacing": "0.1em",
        "border_radius": "0px",
        "hover": {
          "background": "#FFFFFF",
          "color": "#000000",
          "border": "2px solid #000000"
        },
        "focus_visible": {
          "outline": "3px solid #000000",
          "outline_offset": "3px"
        },
        "cta_arrow": "→",
        "cta_arrow_note": "Consider appending → for call-to-action buttons"
      },
      "secondary": {
        "background": "transparent",
        "color": "#000000",
        "border": "2px solid #000000",
        "padding": "16px 32px",
        "font_family": "mono",
        "font_size": "0.875rem",
        "font_weight": 500,
        "text_transform": "uppercase",
        "letter_spacing": "0.1em",
        "border_radius": "0px",
        "hover": {
          "background": "#000000",
          "color": "#FFFFFF"
        }
      },
